---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { defaultLinks, teamMembers } from "../data/site";

const createLinks = () => ({ ...defaultLinks });
---

<Layout title="Equipo | CogNeuroEdu" description="Equipo investigador de CogNeuroEdu en la UNED.">
	<Navbar />
	<main class="px-5 pb-16 pt-32 md:px-8 md:pb-24 md:pt-40">
		<section class="page-frame grid gap-8 lg:grid-cols-[0.84fr_1.16fr] lg:items-end">
			<div class="reveal space-y-6">
				<p class="eyebrow kicker-rule">Equipo</p>
				<h1 class="text-5xl font-semibold leading-[0.93] tracking-[-0.05em] sm:text-6xl md:text-7xl">
					Un equipo interdisciplinar visible, coherente y fácil de consultar.
				</h1>
			</div>
			<p class="reveal section-lead max-w-none" style="--reveal-delay: 120ms;">
				La página de equipo se reorganiza para dar más protagonismo a las personas, clarificar roles y mantener una
				presentación sobria acorde con la identidad académica del proyecto.
			</p>
		</section>

		<section class="page-frame section-shell">
			<div class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
				{teamMembers.map((member, index) => {
					const links = createLinks();
					return (
						<article class="reveal editorial-panel flex flex-col p-6 text-center md:p-8" style={`--reveal-delay: ${index * 60}ms;`}>
							<div class="mx-auto mb-6 h-28 w-28 overflow-hidden rounded-full border border-[rgba(217,207,192,0.95)] bg-[rgba(232,234,223,0.45)]">
								<img
									src={member.image.src}
									alt={member.image.alt}
									loading="lazy"
									class="h-full w-full object-cover"
									onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden')"
								/>
								<div class="hidden h-full items-center justify-center bg-[linear-gradient(180deg,#1d2f50,#31466d)] text-2xl font-semibold text-white">
									{member.image.placeholder}
								</div>
							</div>
							<h2 class="text-2xl font-semibold leading-tight tracking-[-0.03em]">{member.name}</h2>
							<p class="mt-3 text-[0.74rem] uppercase tracking-[0.22em] text-[#5f6b85]">{member.role}</p>
							{member.highlight && <p class="mt-4 text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-[#d08e29]">{member.highlight}</p>}
							<div class="mt-8 flex flex-wrap items-center justify-center gap-3">
								<a
									class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgba(208,142,41,0.35)] text-[#1d2f50] hover:bg-[#d08e29] hover:text-white"
									href={links.orcid}
									aria-label={`ORCID de ${member.name}`}
								>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><circle cx="12" cy="12" r="11"></circle><text x="12" y="15" text-anchor="middle" font-size="9" font-family="sans-serif" fill="white">iD</text></svg>
								</a>
								<a
									class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgba(208,142,41,0.35)] text-[#1d2f50] hover:bg-[#d08e29] hover:text-white"
									href={`mailto:${links.email}`}
									aria-label={`Escribir a ${member.name}`}
								>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M4 6h16c.55 0 1 .45 1 1v10c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1V7c0-.55.45-1 1-1zm0 2v8h16V8l-8 5-8-5zm8 3 8-5H4l8 5z"></path></svg>
								</a>
								<a
									class="flex h-10 w-10 items-center justify-center rounded-full border border-[rgba(208,142,41,0.35)] text-[#1d2f50] hover:bg-[#d08e29] hover:text-white"
									href={links.profile}
									target="_blank"
									rel="noreferrer"
									aria-label={`Perfil universitario de ${member.name}`}
								>
									<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-5 w-5 fill-current"><path d="M12 3 2 8l10 5 10-5-10-5zm0 7L4 6v9h2v-4l6 3 6-3v4h2V6l-8 4zm-6 8h12v2H6v-2z"></path></svg>
								</a>
							</div>
						</article>
					);
				})}
			</div>
		</section>
	</main>
	<Footer />
</Layout>
