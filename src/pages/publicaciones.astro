---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { publications } from "../data/site";
---

<Layout title="Publicaciones | CogNeuroEdu" description="Archivo editorial de publicaciones y documentos científicos de CogNeuroEdu.">
	<Navbar />
	<main class="px-5 pb-16 pt-32 md:px-8 md:pb-24 md:pt-40">
		<section class="page-frame grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
			<div class="reveal space-y-6">
				<p class="eyebrow kicker-rule">Publicaciones</p>
				<h1 class="text-5xl font-semibold leading-[0.93] tracking-[-0.05em] sm:text-6xl md:text-7xl">
					Producción científica ordenada para consulta rápida y lectura profunda.
				</h1>
			</div>
			<p class="reveal section-lead max-w-none" style="--reveal-delay: 120ms;">
				La salida científica se presenta con una lógica editorial clara: tipo de publicación, fecha, foco temático y
				resumen breve para orientar mejor la exploración del contenido académico.
			</p>
		</section>

		<section class="page-frame section-shell">
			<div class="reveal editorial-panel p-6 md:p-10">
				<div class="space-y-8">
					{publications.map((item, index) => (
						<article class="grid gap-5 border-b border-[rgba(217,207,192,0.8)] pb-8 last:border-none last:pb-0 md:grid-cols-[160px_minmax(0,1fr)]">
							<div class="text-sm font-semibold uppercase tracking-[0.24em] text-[#d08e29]">
								<div>{item.type}</div>
								<div class="mt-2 text-[#5f6b85]">{item.year}</div>
								<div class="mt-5 text-[0.68rem] text-[#5f6b85]">Registro {index + 1}</div>
							</div>
							<div>
								<h2 class="text-3xl font-semibold leading-tight tracking-[-0.04em] md:text-4xl">{item.title}</h2>
								<p class="mt-4 max-w-4xl text-base leading-7 text-[#5f6b85] md:text-lg md:leading-8">{item.summary}</p>
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="page-frame section-shell section-divider">
			<div class="grid gap-6 md:grid-cols-2">
				<div class="reveal editorial-card p-6 md:p-8">
					<h2 class="mb-4 text-2xl font-semibold tracking-[-0.03em]">Lectura optimizada</h2>
					<p class="text-base leading-7 text-[#5f6b85]">
						La nueva presentación reduce densidad visual y hace más sencilla la identificación de piezas relevantes por
						fecha, formato y ámbito temático.
					</p>
				</div>
				<div class="reveal editorial-card p-6 md:p-8" style="--reveal-delay: 100ms;">
					<h2 class="mb-4 text-2xl font-semibold tracking-[-0.03em]">Siguiente mejora sugerida</h2>
					<p class="text-base leading-7 text-[#5f6b85]">
						Conectar esta sección con referencias reales, DOI, filtros por año y exportación bibliográfica para convertir
						el archivo en un repositorio científico completo.
					</p>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
