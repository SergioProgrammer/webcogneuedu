---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { contactChannels } from "../data/site";
---

<Layout title="Contacto | CogNeuroEdu" description="Canales de contacto y colaboración para proyectos, publicaciones y actividad académica de CogNeuroEdu.">
	<Navbar />
	<main class="px-5 pb-16 pt-32 md:px-8 md:pb-24 md:pt-40">
		<section class="page-frame grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
			<div class="reveal space-y-6">
				<p class="eyebrow kicker-rule">Contacto</p>
				<h1 class="text-5xl font-semibold leading-[0.93] tracking-[-0.05em] sm:text-6xl md:text-7xl">
					Canales claros para colaboración, consulta e intercambio académico.
				</h1>
			</div>
			<p class="reveal section-lead max-w-none" style="--reveal-delay: 120ms;">
				Se ha reorganizado el acceso al grupo para que instituciones, investigadoras, profesionales y redes colaboradoras
				encuentren rápidamente la vía de contacto adecuada.
			</p>
		</section>

		<section class="page-frame section-shell">
			<div class="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
				<div class="reveal editorial-panel p-6 md:p-10">
					<div class="space-y-6">
						{contactChannels.map((item) => (
							<div class="border-b border-[rgba(217,207,192,0.8)] pb-5 last:border-none last:pb-0">
								<p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.28em] text-[#d08e29]">{item.label}</p>
								<a
									class="text-xl font-semibold leading-tight tracking-[-0.03em] text-[#1d2f50] hover:text-[#d08e29] md:text-2xl"
									href={item.href}
									target={item.href.startsWith("http") ? "_blank" : undefined}
									rel={item.href.startsWith("http") ? "noreferrer" : undefined}
								>
									{item.value}
								</a>
							</div>
						))}
					</div>
				</div>
				<div class="reveal editorial-card p-6 md:p-8" style="--reveal-delay: 120ms;">
					<h2 class="mb-5 text-3xl font-semibold leading-tight tracking-[-0.04em]">Qué tipo de contacto priorizamos</h2>
					<ul class="space-y-4 text-base leading-7 text-[#5f6b85]">
						<li>Consultas sobre líneas de investigación, publicaciones y actividad académica.</li>
						<li>Propuestas de colaboración entre universidades, grupos, cátedras y centros.</li>
						<li>Solicitudes de transferencia, participación en proyectos y difusión científica.</li>
					</ul>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
