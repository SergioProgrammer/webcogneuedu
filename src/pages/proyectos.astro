---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import { featuredProjects } from "../data/site";
---

<Layout title="Proyectos | CogNeuroEdu" description="Proyectos destacados, redes científicas e instituciones colaboradoras de CogNeuroEdu.">
	<Navbar />
	<main class="px-5 pb-16 pt-32 md:px-8 md:pb-24 md:pt-40">
		<section class="page-frame grid gap-8 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
			<div class="reveal space-y-6">
				<p class="eyebrow kicker-rule">Proyectos y transferencia</p>
				<h1 class="text-5xl font-semibold leading-[0.93] tracking-[-0.05em] sm:text-6xl md:text-7xl">
					Proyectos conectados con redes, instituciones y contextos de aplicación.
				</h1>
			</div>
			<p class="reveal section-lead max-w-none" style="--reveal-delay: 120ms;">
				El trabajo del grupo se articula a través de colaboraciones que multiplican alcance, permiten transferencia y
				refuerzan la dimensión internacional de la investigación.
			</p>
		</section>

		<section class="page-frame section-shell">
			<div class="grid gap-5 lg:grid-cols-3">
				{featuredProjects.map((project, index) => (
					<article class="reveal editorial-panel flex h-full flex-col p-6 md:p-8" style={`--reveal-delay: ${index * 100}ms;`}>
						<div class="mb-6 flex h-44 items-center justify-center rounded-[1.5rem] bg-[rgba(232,234,223,0.46)] p-6">
							<img src={project.image} alt={project.alt} loading="lazy" class="max-h-full max-w-full object-contain" />
						</div>
						<p class="mb-2 text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-[#d08e29]">{project.tag}</p>
						<h2 class="mb-4 text-3xl font-semibold leading-tight tracking-[-0.04em]">{project.title}</h2>
						<p class="text-base leading-7 text-[#5f6b85] md:text-lg md:leading-8">{project.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="page-frame section-shell section-divider">
			<div class="grid gap-6 md:grid-cols-2">
				<div class="reveal editorial-card p-6 md:p-8">
					<h2 class="mb-4 text-2xl font-semibold tracking-[-0.03em]">Valor de transferencia</h2>
					<p class="text-base leading-7 text-[#5f6b85]">
						Estos proyectos permiten convertir resultados académicos en marcos de actuación, materiales, redes de datos y
						colaboraciones sostenibles.
					</p>
				</div>
				<div class="reveal editorial-card p-6 md:p-8" style="--reveal-delay: 110ms;">
					<h2 class="mb-4 text-2xl font-semibold tracking-[-0.03em]">Escala institucional</h2>
					<p class="text-base leading-7 text-[#5f6b85]">
						La narrativa visual se ha simplificado para mostrar mejor la relación entre investigación, financiación,
						colaboración y aplicación social.
					</p>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>
