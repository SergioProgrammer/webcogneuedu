---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import {
	collaborators,
	featuredProjects,
	metrics,
	publications,
	researchLines,
	siteMeta,
	teamMembers,
} from "../data/site";
---

<Layout title={siteMeta.title} description={siteMeta.description}>
	<Navbar />

	<main>
		<section class="relative overflow-hidden px-5 pb-16 pt-32 md:px-8 md:pb-24 md:pt-40">
			<div class="page-frame grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_minmax(320px,0.8fr)] lg:items-end">
				<div class="reveal space-y-8">
					<p class="eyebrow kicker-rule">Grupo de investigación · Facultad de Educación · UNED</p>
					<div class="space-y-6">
						<h1 class="max-w-5xl text-5xl font-semibold leading-[0.92] tracking-[-0.05em] sm:text-6xl md:text-7xl lg:text-[6.1rem]">
							Investigación en lenguaje, cognición y neuroeducación con transferencia real.
						</h1>
						<p class="max-w-3xl text-lg leading-8 text-[#5f6b85] md:text-xl md:leading-9">
							Exploramos cómo diseñar, validar y trasladar evidencia científica a contextos educativos y clínicos para
							mejorar el desarrollo comunicativo, la accesibilidad y la salud cognitiva.
						</p>
					</div>
					<div class="flex flex-col gap-4 sm:flex-row">
						<a class="cta-primary" href="/investigacion">Ver investigación</a>
						<a class="cta-secondary" href="/publicaciones">Explorar publicaciones</a>
					</div>
				</div>

				<div class="reveal editorial-panel relative overflow-hidden p-6 md:p-8 lg:min-h-[34rem]" style="--reveal-delay: 140ms;">
					<div class="absolute inset-x-8 top-8 h-px bg-[linear-gradient(90deg,rgba(29,47,80,0.12),rgba(208,142,41,0.5),rgba(29,47,80,0.12))]"></div>
					<div class="grid h-full gap-10 pt-8">
						<div class="space-y-5">
							<p class="text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-[#5f6b85]">Foco actual</p>
							<h2 class="text-3xl font-semibold leading-tight tracking-[-0.04em] md:text-4xl">
								Intervención temprana, creatividad aplicada y herramientas de investigación legibles.
							</h2>
						</div>
						<div class="grid gap-6 border-t border-[rgba(217,207,192,0.8)] pt-6">
							{metrics.map((item) => (
								<div class="grid gap-2 border-b border-[rgba(217,207,192,0.75)] pb-5 last:border-none last:pb-0">
									<span class="stat-value">{item.value}</span>
									<p class="max-w-xs text-sm uppercase tracking-[0.14em] text-[#5f6b85]">{item.label}</p>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="section-shell section-divider">
			<div class="page-frame grid gap-8 lg:grid-cols-[0.78fr_1.22fr]">
				<div class="reveal space-y-5">
					<p class="eyebrow">Investigación</p>
					<h2 class="section-title">Líneas de investigación claras, interdisciplinarias y aplicadas.</h2>
					<p class="section-lead">
						La estructura científica del grupo se organiza en bloques amplios y reconocibles para facilitar tanto la
						lectura rápida como la consulta en profundidad.
					</p>
				</div>
				<div class="grid gap-5">
					{researchLines.map((line, index) => (
						<article class="reveal editorial-card p-6 md:p-8" style={`--reveal-delay: ${index * 100}ms;`} id={line.id}>
							<div class="mb-6 flex items-start justify-between gap-4 border-b border-[rgba(217,207,192,0.8)] pb-4">
								<p class="text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-[#d08e29]">0{index + 1}</p>
								<h3 class="max-w-xl text-2xl font-semibold leading-tight tracking-[-0.03em] md:text-3xl">{line.title}</h3>
							</div>
							<p class="mb-5 max-w-2xl text-base leading-7 text-[#5f6b85] md:text-lg md:leading-8">{line.description}</p>
							<ul class="grid gap-3 text-sm uppercase tracking-[0.16em] text-[#1d2f50] md:grid-cols-3 md:text-[0.78rem]">
								{line.points.map((point) => (
									<li class="rounded-full border border-[rgba(217,207,192,0.9)] bg-white/65 px-4 py-3">{point}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section-shell section-divider">
			<div class="page-frame grid gap-10 lg:grid-cols-[minmax(0,0.72fr)_minmax(0,1.28fr)]">
				<div class="reveal space-y-5">
					<p class="eyebrow">Proyectos</p>
					<h2 class="section-title">Transferencia, redes e instituciones que amplían el impacto.</h2>
					<p class="section-lead">
						La actividad científica del grupo se conecta con instituciones y consorcios que permiten escalar resultados,
						compartir datos y fortalecer la cooperación académica.
					</p>
					<a class="cta-secondary" href="/proyectos">Ver todos los proyectos</a>
				</div>
				<div class="grid gap-5 md:grid-cols-3">
					{featuredProjects.map((project, index) => (
						<article class="reveal editorial-card flex h-full flex-col p-5 md:p-6" style={`--reveal-delay: ${index * 120}ms;`}>
							<div class="mb-5 flex h-40 items-center justify-center rounded-[1.25rem] bg-[rgba(232,234,223,0.48)] p-5">
								<img src={project.image} alt={project.alt} loading="lazy" class="max-h-full max-w-full object-contain" />
							</div>
							<p class="mb-2 text-[0.7rem] font-semibold uppercase tracking-[0.28em] text-[#d08e29]">{project.tag}</p>
							<h3 class="mb-3 text-2xl font-semibold leading-tight tracking-[-0.03em]">{project.title}</h3>
							<p class="mb-6 text-base leading-7 text-[#5f6b85]">{project.description}</p>
							<a class="mt-auto text-sm font-semibold uppercase tracking-[0.22em] text-[#1d2f50] hover:text-[#d08e29]" href={project.link}>
								Ampliar
							</a>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section-shell section-divider">
			<div class="page-frame grid gap-8 lg:grid-cols-[0.75fr_1.25fr]">
				<div class="reveal space-y-5">
					<p class="eyebrow">Publicaciones</p>
					<h2 class="section-title">Salida científica con mejor legibilidad y jerarquía.</h2>
					<p class="section-lead">
						Presentamos la producción del grupo como un archivo editorial: más escaneable, más preciso y más fácil de
						consultar para investigación, docencia o colaboración.
					</p>
				</div>
				<div class="reveal editorial-panel p-6 md:p-8 lg:p-10" style="--reveal-delay: 120ms;">
					<div class="space-y-6">
						{publications.map((item) => (
							<article class="grid gap-4 border-b border-[rgba(217,207,192,0.8)] pb-6 last:border-none last:pb-0 md:grid-cols-[110px_minmax(0,1fr)]">
								<div class="text-sm font-semibold uppercase tracking-[0.24em] text-[#d08e29]">
									<div>{item.type}</div>
									<div class="mt-1 text-[#5f6b85]">{item.year}</div>
								</div>
								<div>
									<h3 class="text-2xl font-semibold leading-tight tracking-[-0.03em]">{item.title}</h3>
									<p class="mt-3 max-w-3xl text-base leading-7 text-[#5f6b85]">{item.summary}</p>
								</div>
							</article>
						))}
					</div>
					<a class="cta-secondary mt-8" href="/publicaciones">Ir al archivo completo</a>
				</div>
			</div>
		</section>

		<section class="section-shell section-divider">
			<div class="page-frame grid gap-8 lg:grid-cols-[0.72fr_1.28fr]">
				<div class="reveal space-y-5">
					<p class="eyebrow">Equipo</p>
					<h2 class="section-title">Talento académico visible, accesible y mejor organizado.</h2>
					<p class="section-lead">
						Mostramos la composición del grupo con un tratamiento sobrio y homogéneo, reforzando perfiles, roles y vías
						de contacto sin ruido visual.
					</p>
					<a class="cta-secondary" href="/team">Ver equipo completo</a>
				</div>
				<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{teamMembers.slice(0, 6).map((member, index) => (
						<article class="reveal editorial-card p-5 text-center md:p-6" style={`--reveal-delay: ${index * 80}ms;`}>
							<div class="mx-auto mb-5 h-24 w-24 overflow-hidden rounded-full border border-[rgba(217,207,192,0.95)] bg-[rgba(232,234,223,0.4)]">
								<img src={member.image.src} alt={member.image.alt} loading="lazy" class="h-full w-full object-cover" />
							</div>
							<h3 class="text-lg font-semibold leading-tight">{member.name}</h3>
							<p class="mt-2 text-[0.72rem] uppercase tracking-[0.22em] text-[#5f6b85]">{member.role}</p>
							{member.highlight && <p class="mt-3 text-[0.72rem] font-semibold uppercase tracking-[0.3em] text-[#d08e29]">{member.highlight}</p>}
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="section-shell section-divider">
			<div class="page-frame grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-end">
				<div class="reveal editorial-panel p-7 md:p-10 lg:p-12">
					<p class="eyebrow">Colaboraciones</p>
					<h2 class="mt-4 max-w-3xl text-3xl font-semibold leading-tight tracking-[-0.04em] md:text-5xl">
						Una plataforma de investigación más clara también mejora la conexión con instituciones, equipos y proyectos.
					</h2>
					<div class="mt-8 grid gap-3 sm:grid-cols-2">
						{collaborators.map((item) => (
							<div class="rounded-full border border-[rgba(217,207,192,0.9)] bg-white/70 px-5 py-4 text-sm font-semibold uppercase tracking-[0.18em] text-[#1d2f50]">
								{item.name}
							</div>
						))}
					</div>
				</div>
				<div class="reveal space-y-5" style="--reveal-delay: 140ms;">
					<p class="eyebrow">Contacto</p>
					<h2 class="text-3xl font-semibold leading-tight tracking-[-0.04em] md:text-4xl">Abrimos conversación para investigación, transferencia y alianzas.</h2>
					<p class="text-base leading-7 text-[#5f6b85] md:text-lg md:leading-8">
						Si tu institución, proyecto o equipo quiere colaborar, participar o conocer mejor la actividad del grupo,
						hemos simplificado los puntos de acceso para que todo sea más directo.
					</p>
					<a class="cta-primary" href="/contacto">Contactar</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>
